+export function cleanWord(word: string): string {
+  return word
+    .toLowerCase()
+    .replace(/[áä]/g, 'a')
+    .replace(/[éë]/g, 'e')
+    .replace(/[íï]/g, 'i')
+    .replace(/[óö]/g, 'o')
+    .replace(/[úü]/g, 'u')
+    .toUpperCase();
+}
+
